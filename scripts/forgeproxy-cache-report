#!/run/current-system/sw/bin/perl
use strict;
use warnings;
use feature 'say';
use Getopt::Long qw(GetOptions);
use JSON::PP;
use File::Find;
use File::Spec;
use Cwd qw(realpath);

my $cache_root = "/var/cache/forgeproxy";
my $format = "table";
my %layout = (
    published_root => "published",
    mirrors_root => "mirrors",
    snapshots_root => "snapshots",
    state_root => ".state",
    state_generations_root => File::Spec->catdir(".state", "generations"),
    state_delta_root => File::Spec->catdir(".state", "delta"),
    state_tee_root => File::Spec->catdir(".state", "tee"),
);

my $usage = "usage: forgeproxy-cache-report [--cache-root PATH] [--format table|json] [owner/repo]\n";

GetOptions(
    "cache-root=s" => \$cache_root,
    "format=s" => \$format,
) or die $usage;

die "--format must be table or json\n" unless $format eq "table" || $format eq "json";
die $usage if @ARGV > 1;

my $repo_slug = shift @ARGV;
if (defined $repo_slug) {
    die "repo must be owner/repo\n" unless $repo_slug =~ m{/};
}

my @component_order = qw(
  published_path
  published_generation
  mirror
  retained_generations
  delta
  tee
  snapshots
);

sub normalize_repo_slug {
    my ($slug) = @_;
    my ($owner, $repo) = split m{/}, $slug, 2;
    $repo =~ s/\.git$//;
    return "$owner/$repo";
}

sub collect_repo_slugs_under_root {
    my ($root, $strip_git_suffix) = @_;
    my %slugs;
    return %slugs unless -d $root;

    opendir(my $owners_dh, $root) or die "opendir $root: $!";
    my @owners = grep {
        my $path = File::Spec->catdir($root, $_);
        !/^\.\.?$/ && -d $path
    } readdir($owners_dh);
    closedir($owners_dh);

    for my $owner (@owners) {
        my $owner_root = File::Spec->catdir($root, $owner);
        opendir(my $repo_dh, $owner_root) or die "opendir $owner_root: $!";
        my @entries = grep { !/^\.\.?$/ } readdir($repo_dh);
        closedir($repo_dh);

        for my $entry (@entries) {
            my $full_path = File::Spec->catfile($owner_root, $entry);
            next unless -d $full_path || -l $full_path || -f $full_path;
            my $repo = $entry;
            $repo =~ s/\.git$// if $strip_git_suffix;
            $slugs{"$owner/$repo"} = 1;
        }
    }

    return %slugs;
}

sub collect_repo_slugs {
    my ($root) = @_;
    my %slugs;

    for my $pair (
        [ File::Spec->catdir($root, $layout{published_root}), 1 ],
        [ File::Spec->catdir($root, $layout{mirrors_root}), 1 ],
        [ File::Spec->catdir($root, $layout{state_generations_root}), 1 ],
        [ File::Spec->catdir($root, $layout{state_delta_root}), 1 ],
        [ File::Spec->catdir($root, $layout{state_tee_root}), 0 ],
        [ File::Spec->catdir($root, $layout{snapshots_root}), 0 ],
    ) {
        my ($path, $strip_git_suffix) = @$pair;
        my %found = collect_repo_slugs_under_root($path, $strip_git_suffix);
        @slugs{keys %found} = values %found;
    }

    return sort keys %slugs;
}

sub component_paths {
    my ($root, $owner_name, $repo_name) = @_;
    my $published_path = File::Spec->catfile(
        $root,
        $layout{published_root},
        $owner_name,
        "$repo_name.git",
    );
    my @published_generation;
    if (-l $published_path) {
        my $resolved = realpath($published_path);
        @published_generation = defined $resolved ? ($resolved) : ();
    }

    my $generations_root = File::Spec->catdir(
        $root,
        $layout{state_generations_root},
        $owner_name,
        "$repo_name.git",
    );
    my @generation_dirs = ();
    if (-d $generations_root) {
        opendir(my $dh, $generations_root) or die "opendir $generations_root: $!";
        @generation_dirs = sort grep { -d File::Spec->catdir($generations_root, $_) && !/^\.\.?$/ } readdir($dh);
        closedir($dh);
        @generation_dirs = map { File::Spec->catdir($generations_root, $_) } @generation_dirs;
    }

    my $delta_root = File::Spec->catdir(
        $root,
        $layout{state_delta_root},
        $owner_name,
        "$repo_name.git",
    );
    my @delta_dirs = ();
    if (-d $delta_root) {
        opendir(my $dh, $delta_root) or die "opendir $delta_root: $!";
        @delta_dirs = sort grep { -d File::Spec->catdir($delta_root, $_) && !/^\.\.?$/ } readdir($dh);
        closedir($dh);
        @delta_dirs = map { File::Spec->catdir($delta_root, $_) } @delta_dirs;
    }

    my $tee_root = File::Spec->catdir($root, $layout{state_tee_root}, $owner_name, $repo_name);
    my @tee_dirs = ();
    if (-d $tee_root) {
        opendir(my $dh, $tee_root) or die "opendir $tee_root: $!";
        @tee_dirs = sort grep { -d File::Spec->catdir($tee_root, $_) && !/^\.\.?$/ } readdir($dh);
        closedir($dh);
        @tee_dirs = map { File::Spec->catdir($tee_root, $_) } @tee_dirs;
    }

    my $snapshot_root = File::Spec->catdir($root, $layout{snapshots_root}, $owner_name, $repo_name);
    my @snapshots = ();
    if (-d $snapshot_root) {
        opendir(my $dh, $snapshot_root) or die "opendir $snapshot_root: $!";
        @snapshots = sort grep { !/^\.\.?$/ } readdir($dh);
        closedir($dh);
        @snapshots = map { File::Spec->catfile($snapshot_root, $_) } @snapshots;
    }

    return {
        published_path => [ $published_path ],
        published_generation => \@published_generation,
        mirror => [ File::Spec->catdir($root, $layout{mirrors_root}, $owner_name, "$repo_name.git") ],
        retained_generations => \@generation_dirs,
        delta => \@delta_dirs,
        tee => \@tee_dirs,
        snapshots => \@snapshots,
    };
}

sub collect_files {
    my ($path) = @_;
    my @records;
    return @records unless -e $path;
    if (-f $path) {
        my @stat = stat($path);
        push @records, {
            path => $path,
            size => $stat[7],
            inode_key => join(":", $stat[0], $stat[1]),
        };
        return @records;
    }

    find(
        {
            no_chdir => 1,
            wanted => sub {
                return unless -f $_;
                my @stat = stat($_) or return;
                push @records, {
                    path => $_,
                    size => $stat[7],
                    inode_key => join(":", $stat[0], $stat[1]),
                };
            },
        },
        $path,
    );
    return @records;
}

sub build_report {
    my ($root, $slug) = @_;
    my ($owner, $repo) = split m{/}, normalize_repo_slug($slug), 2;
    my $paths = component_paths($root, $owner, $repo);
    my %component_records;
    my %inode_components;
    my %inode_sizes;

    for my $component (@component_order) {
        for my $path (@{ $paths->{$component} // [] }) {
            for my $record (collect_files($path)) {
                push @{ $component_records{$component} }, $record;
                $inode_components{ $record->{inode_key} }{$component} = 1;
                $inode_sizes{ $record->{inode_key} } = $record->{size};
            }
        }
    }

    my @components;
    my %total_unique_inodes;
    for my $component (@component_order) {
        my $records = $component_records{$component} // [];
        my $apparent_size = 0;
        my $unique_size = 0;
        my %seen_component_unique;

        for my $record (@$records) {
            $apparent_size += $record->{size};
            $total_unique_inodes{ $record->{inode_key} } = 1;
            my @owners = keys %{ $inode_components{ $record->{inode_key} } };
            if (@owners == 1 && $owners[0] eq $component && !$seen_component_unique{ $record->{inode_key} }++) {
                $unique_size += $record->{size};
            }
        }

        push @components, {
            component => $component,
            path_count => scalar @{ $paths->{$component} // [] },
            file_count => scalar @$records,
            apparent_size_bytes => $apparent_size,
            unique_size_bytes => $unique_size,
            shared_size_bytes => $apparent_size - $unique_size,
            paths => $paths->{$component} // [],
        };
    }

    my $published_path = $paths->{published_path}[0];
    my $published_generation_path = -l $published_path ? realpath($published_path) : undef;
    my $total_unique_size = 0;
    $total_unique_size += $inode_sizes{$_} for keys %total_unique_inodes;

    return {
        repo => "$owner/$repo",
        cache_root => $root,
        published_path => $published_path,
        published_generation_path => $published_generation_path,
        total_unique_size_bytes => $total_unique_size,
        components => \@components,
    };
}

sub human_size {
    my ($size) = @_;
    my @units = ("B", "KiB", "MiB", "GiB", "TiB");
    my $value = $size + 0.0;
    for my $unit (@units) {
        return $unit eq "B" ? sprintf("%d%s", $value, $unit) : sprintf("%.1f%s", $value, $unit)
          if $value < 1024 || $unit eq $units[-1];
        $value /= 1024.0;
    }
    return "${size}B";
}

my $report_all = !defined $repo_slug;
my @repo_slugs = $report_all ? collect_repo_slugs($cache_root) : (normalize_repo_slug($repo_slug));
my @reports = map { build_report($cache_root, $_) } @repo_slugs;

if ($format eq "json") {
    if ($report_all) {
        my $total_reported_unique_size = 0;
        $total_reported_unique_size += $_->{total_unique_size_bytes} for @reports;
        say JSON::PP->new->ascii->pretty->canonical->encode({
            cache_root => $cache_root,
            repo_count => scalar(@reports),
            total_reported_unique_size_bytes => $total_reported_unique_size,
            repos => \@reports,
        });
    } else {
        say JSON::PP->new->ascii->pretty->canonical->encode($reports[0]);
    }
    exit 0;
}

if ($report_all) {
    my $total_reported_unique_size = 0;
    $total_reported_unique_size += $_->{total_unique_size_bytes} for @reports;
    say "cache_root: $cache_root";
    say "repo_count: " . scalar(@reports);
    say "total_reported_unique_size: " . human_size($total_reported_unique_size);
    say "";
    printf "%-36s %-18s %5s %7s %12s %12s %12s\n", "repo", "component", "paths", "files", "apparent", "unique", "shared";
    say "-" x 108;
    for my $report (@reports) {
        for my $component (@{ $report->{components} }) {
            printf "%-36s %-18s %5d %7d %12s %12s %12s\n",
              $report->{repo},
              $component->{component},
              $component->{path_count},
              $component->{file_count},
              human_size($component->{apparent_size_bytes}),
              human_size($component->{unique_size_bytes}),
              human_size($component->{shared_size_bytes});
        }
    }
    exit 0;
}

my $report = $reports[0];
say "repo: $report->{repo}";
say "cache_root: $report->{cache_root}";
say "published_path: $report->{published_path}";
say "published_generation_path: $report->{published_generation_path}" if defined $report->{published_generation_path};
say "total_unique_size: " . human_size($report->{total_unique_size_bytes});
say "";
printf "%-18s %5s %7s %12s %12s %12s\n", "component", "paths", "files", "apparent", "unique", "shared";
say "-" x 72;
for my $component (@{ $report->{components} }) {
    printf "%-18s %5d %7d %12s %12s %12s\n",
      $component->{component},
      $component->{path_count},
      $component->{file_count},
      human_size($component->{apparent_size_bytes}),
      human_size($component->{unique_size_bytes}),
      human_size($component->{shared_size_bytes});
}
