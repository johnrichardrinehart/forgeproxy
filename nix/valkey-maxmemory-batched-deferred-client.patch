+proc send_deferred_command_batches {client cmd_count command {batch_size 1000}} {
+    set batch {}
+    set batched_count 0
+
+    for {set k 0} {$k < $cmd_count} {incr k} {
+        append batch $command
+        incr batched_count
+
+        if {$batched_count == $batch_size} {
+            $client write $batch
+            $client flush
+            set batch {}
+            set batched_count 0
+        }
+    }
+
+    if {$batched_count > 0} {
+        $client write $batch
+        $client flush
+    }
+}
