diff --git a/src/arena.c b/src/arena.c
index 962a325d..17c1c0ed 100644
--- a/src/arena.c
+++ b/src/arena.c
@@ -30,6 +30,7 @@ ssize_t opt_muzzy_decay_ms = MUZZY_DECAY_MS_DEFAULT;
 
 static atomic_zd_t dirty_decay_ms_default;
 static atomic_zd_t muzzy_decay_ms_default;
+static atomic_zu_t arena_dalloc_small_missing_edata = ATOMIC_INIT(0);
 
 emap_t              arena_emap_global;
 static pa_central_t arena_pa_central_global;
@@ -1466,6 +1467,25 @@ arena_dalloc_bin(tsdn_t *tsdn, arena_t *arena, edata_t *edata, void *ptr) {
 void
 arena_dalloc_small(tsdn_t *tsdn, void *ptr) {
 	edata_t *edata = emap_edata_lookup(tsdn, &arena_emap_global, ptr);
+	if (unlikely(edata == NULL)) {
+		atomic_fetch_add_zu(&arena_dalloc_small_missing_edata,
+		    1, ATOMIC_RELAXED);
+		if (config_opt_safety_checks) {
+			safety_check_fail(
+			    "<jemalloc>: invalid deallocation detected "
+			    "(pointer %p is not present in the extent map). "
+			    "Likely caused by application deallocation bugs. "
+			    "Abort.\n",
+			    ptr);
+			return;
+		}
+		/*
+		 * Avoid crashing in dependent lookup paths when a pointer is not
+		 * present in jemalloc's extent map.  This keeps production
+		 * processes alive while safety-check builds still fail loudly.
+		 */
+		return;
+	}
 	arena_t *arena = arena_get_from_edata(edata);
 
 	arena_dalloc_bin(tsdn, arena, edata, ptr);
