# AWS Configuration
aws_region = "us-east-1"
# aws_profile = "your-sso-profile"

# Resource naming
name_prefix = "forgeproxy"

# Closure variant: "hardened" (default) or "dev"
closure_variant = "hardened"
# Set true to disallow Nix from building anything locally.
# disallow_local_nix_builds = false

# Upstream forge configuration
upstream_hostname  = "ghe.example.com"
upstream_port      = 443
upstream_ssh_port  = 22
upstream_api_url   = "https://ghe.example.com/api/v3"
backend_type       = "github-enterprise"

# Client-facing TLS hostnames for the NLB listener
nlb_tls_cert_arns_by_hostname = {
  "cache.example.com" = "arn:aws:acm:us-east-1:123456789012:certificate/11111111-2222-3333-4444-555555555555"
  "cache-alt.example.com" = "arn:aws:acm:us-east-1:123456789012:certificate/66666666-7777-8888-9999-000000000000"
}

# S3 bundle bucket name (MUST be globally unique)
bundle_bucket_name = "my-org-forgeproxy-bundles-12345"
force_destroy      = false

# Instance types and counts
forgeproxy_instance_type = "t3.large"
forgeproxy_count         = 1
forgeproxy_cutover_check_interval_secs = 15
forgeproxy_cutover_required_consecutive_successes = 8
forgeproxy_cutover_timeout_secs = 600
# forgeproxy_cache_volume_enabled = true
# forgeproxy_cache_volume_gb = 4096
# forgeproxy_cache_volume_iops = 12000
# forgeproxy_cache_volume_throughput_mbps = 500
# forgeproxy_cache_periodic_snapshot_enabled = true
# forgeproxy_cache_periodic_snapshot_interval_secs = 86400
# forgeproxy_cache_seed_snapshot_retention_count = 1
# forgeproxy_ssh_host_key_secret_arn = "arn:aws:secretsmanager:us-east-1:123456789012:secret:shared/forgeproxy-ssh-host-key-AbCdEf"
# forgeproxy_ssh_host_key_kms_key_arn = "arn:aws:kms:us-east-1:123456789012:key/11111111-2222-3333-4444-555555555555"
valkey_instance_type      = "r6i.large"
# valkey_service_name = "valkey"
# valkey_reload_wait_timeout_secs = 600
cache_scrub_on_calendar = "*-*-* 00:00:00 UTC"
cache_scrub_interval_secs = 86400

# Volume sizes (GB)
forgeproxy_root_volume_gb = 50
forgeproxy_root_volume_iops = 3000
forgeproxy_root_volume_throughput_mbps = 125
valkey_root_volume_gb      = 50

# Optional ghe-key-lookup sidecar deployment
enable_ghe_key_lookup                = false
ghe_key_lookup_instance_type         = "t3.small"
ghe_key_lookup_count                 = 1
ghe_key_lookup_root_volume_gb        = 20
ghe_key_lookup_listen_ports          = [3000]
ghe_key_lookup_allowed_cidrs         = []
ghe_key_lookup_ssh_target_endpoint   = "ghe.example.com"
ghe_key_lookup_ghe_url               = "https://ghe.example.com"
ghe_key_lookup_ssh_user              = "admin"
ghe_key_lookup_ssh_port              = 122
auth_ssh_user_lookup_cache_ttl       = 30
auth_ssh_repo_access_cache_ttl       = 30

# Network configuration
vpc_cidr           = "10.0.0.0/16"
public_subnet_cidr = "10.0.1.0/24"
private_subnet_cidr = "10.0.2.0/24"

# Network Load Balancer configuration
nlb_internal = true  # Set to false to expose NLB via public EIP (corporate internal traffic only)
nlb_tls_ssl_policy = "ELBSecurityPolicy-TLS13-1-2-2021-06"

# Access control
allowed_client_cidrs = ["0.0.0.0/0"]  # Restrict this in production
metrics_scrape_cidrs = []              # Add CIDRs for Prometheus scraping

# EC2 key pair (optional, SSM access always available)
ec2_key_pair_name = ""

# Cache configuration
local_cache_max_percent = 0.80
eviction_policy         = "lfu" # or "lru"

# S3 storage configuration
s3_bundle_prefix     = "forgeproxy/"
s3_presigned_url_ttl = 3600

# Logging
log_level = "info"  # trace, debug, info, warn, error
max_concurrent_deep_validations = 1
bundle_max_concurrent_generations = 1

# Organization credentials configuration
org_creds = [
  {
    name = "example-org"
    mode = "pat"
  },
  {
    name = "another-org"
    mode = "pat"
  },
]

# OpenTelemetry configuration (optional)
metrics_enabled = true
metrics_top_heavy_repo_limit = 100
metrics_refresh_interval_secs = 60
config_reload_enabled = true
config_reload_interval_secs = 60
background_work_enabled = true
background_work_defer_when_active_clones = true
background_work_cpu_busy_100ms_high_watermark = 0.80
background_work_load_1m_per_cpu_high_watermark = 0.80
background_work_retry_interval_secs = 60
background_work_max_defer_retries = 10
background_work_max_defer_secs = 1800
prepare_published_generation_midx = true
published_generation_bitmap_policy = "adaptive"
published_generation_bitmap_min_mirror_size_bytes = 524288000
published_generation_bitmap_churn_bytes_threshold = 52428800
published_generation_bitmap_max_interval_ratio = 0.5
global_short_circuit_upstream_secs = 0
request_wait_for_local_catch_up_secs = 30
request_wait_for_active_local_catch_up_secs = 360
request_time_s3_restore_secs = 0
generation_publish_secs = 0
local_upload_pack_first_byte_secs = 0
fetch_schedule_enabled = true
fetch_schedule_evaluation_interval_secs = 30
fetch_schedule_min_interval_secs = 300
fetch_schedule_max_interval_secs = 86400
fetch_schedule_candidate_limit_per_tick = 128
fetch_schedule_max_refreshes_per_tick = 16
fetch_schedule_request_probability_window_secs = 900
fetch_schedule_churn_window_secs = 1800
fetch_schedule_stale_after_secs = 1800
fetch_schedule_jitter_percent = 15
max_concurrent_upstream_clones = 4
max_concurrent_upstream_fetches = 8
reserved_request_time_upstream_fetches = 2
max_concurrent_upstream_clones_per_repo_per_instance = 3
max_concurrent_upstream_clones_per_repo_across_instances = 10
max_concurrent_local_upload_packs = 4
max_concurrent_local_upload_packs_per_repo = 1
max_concurrent_tee_captures = 8
max_concurrent_tee_captures_per_repo_per_instance = 2
# Adaptive repo update defaults. Deploying these values does not reset learned
# per-repo Valkey state; auto mode still uses observed size/ref/failure signals
# unless a repo override or forced global mode is configured.
# Auto mode selects direct_mirror when any threshold is crossed: size OR ref
# count OR learned failure score. The physical ratio is a delta-workspace health
# limit comparing temporary workspace disk use to persistent mirror disk use.
repo_update_mode = "auto"
repo_update_large_repo_size_bytes_threshold = 1073741824
repo_update_large_repo_ref_count_threshold = 10000
repo_update_failure_score_threshold = 3
repo_update_delta_workspace_max_physical_ratio = 0.25
repo_update_overrides = {
  # "foo/deployment" = {
  #   mode = "direct_mirror"
  #   large_repo_ref_count_threshold = 5000
  # }
}
delegated_repositories = []
local_upload_pack_threads = 2
pack_cache_on_demand_composite_total_secs = 0
pack_cache_request_delta_pack_secs = 0
pack_cache_max_concurrent_background_warmings = 1
pack_cache_recent_entry_max_age_secs = 21600
pack_cache_max_recent_repos = 2048
prewarm_enabled = false
prewarm_repos = []
prewarm_max_concurrent = 2
prewarm_force_open_secs = 1500
health_check_timeout_secs = 5
health_disk_min_available_percent = 5.0
bundle_pack_threads = 4
logs_enabled = true
traces_enabled = false
traces_sample_ratio = 1.0

otlp_metrics = {
  endpoint             = ""
  protocol             = "grpc"
  export_interval_secs = 60
  basic_auth_username  = ""
  basic_auth_password  = ""
}

host_metrics_enabled = false

otlp_logs = {
  endpoint             = ""
  protocol             = "grpc"
  export_interval_secs = 60
  basic_auth_username  = ""
  basic_auth_password  = ""
}

otlp_traces = {
  endpoint             = ""
  protocol             = "grpc"
  export_interval_secs = 60
  basic_auth_username  = ""
  basic_auth_password  = ""
}
