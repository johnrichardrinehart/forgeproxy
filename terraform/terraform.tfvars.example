# AWS Configuration
aws_region = "us-east-1"
# aws_profile = "your-sso-profile"

# Resource naming
name_prefix = "forgeproxy"

# Closure variant: "hardened" (default) or "dev"
closure_variant = "hardened"

# Upstream forge configuration
upstream_hostname  = "ghe.example.com"
upstream_port      = 443
upstream_api_url   = "https://ghe.example.com/api/v3"
backend_type       = "github-enterprise"

# Client-facing TLS hostnames for the NLB listener
nlb_tls_cert_arns_by_hostname = {
  "cache.example.com" = "arn:aws:acm:us-east-1:123456789012:certificate/11111111-2222-3333-4444-555555555555"
  "cache-alt.example.com" = "arn:aws:acm:us-east-1:123456789012:certificate/66666666-7777-8888-9999-000000000000"
}

# S3 bundle bucket name (MUST be globally unique)
bundle_bucket_name = "my-org-forgeproxy-bundles-12345"
force_destroy      = false

# Instance types and counts
forgeproxy_instance_type = "t3.large"
forgeproxy_count         = 1
# forgeproxy_ssh_host_key_secret_arn = "arn:aws:secretsmanager:us-east-1:123456789012:secret:shared/forgeproxy-ssh-host-key-AbCdEf"
# forgeproxy_ssh_host_key_kms_key_arn = "arn:aws:kms:us-east-1:123456789012:key/11111111-2222-3333-4444-555555555555"
valkey_instance_type      = "r6i.large"

# Volume sizes (GB)
forgeproxy_root_volume_gb = 50
valkey_root_volume_gb      = 50

# Optional ghe-key-lookup sidecar deployment
enable_ghe_key_lookup                = false
ghe_key_lookup_instance_type         = "t3.small"
ghe_key_lookup_count                 = 1
ghe_key_lookup_root_volume_gb        = 20
ghe_key_lookup_listen_ports          = [3000]
ghe_key_lookup_allowed_cidrs         = []
ghe_key_lookup_ssh_target_endpoint   = "ghe.example.com"
ghe_key_lookup_ghe_url               = "https://ghe.example.com"
ghe_key_lookup_ssh_user              = "admin"
ghe_key_lookup_ssh_port              = 122
ghe_key_lookup_cache_ttl_pos         = 300
ghe_key_lookup_cache_ttl_neg         = 30

# Network configuration
vpc_cidr           = "10.0.0.0/16"
public_subnet_cidr = "10.0.1.0/24"
private_subnet_cidr = "10.0.2.0/24"

# Network Load Balancer configuration
nlb_internal = true  # Set to false to expose NLB via public EIP (corporate internal traffic only)
nlb_tls_ssl_policy = "ELBSecurityPolicy-TLS13-1-2-2021-06"

# Access control
allowed_client_cidrs = ["0.0.0.0/0"]  # Restrict this in production
metrics_scrape_cidrs = []              # Add CIDRs for Prometheus scraping

# EC2 key pair (optional, SSM access always available)
ec2_key_pair_name = ""

# Cache configuration
local_cache_max_bytes = 53687091200  # 50 GiB
eviction_policy       = "lfu"         # or "lru"

# S3 storage configuration
s3_bundle_prefix     = "forgeproxy/"
s3_presigned_url_ttl = 3600

# Logging
log_level = "info"  # trace, debug, info, warn, error

# Organization credentials configuration
org_creds = [
  {
    name = "example-org"
    mode = "pat"
  },
  {
    name = "another-org"
    mode = "pat"
  },
]

# OpenTelemetry configuration (optional)
metrics_enabled = true
metrics_refresh_interval_secs = 60
logs_enabled = true
traces_enabled = false
traces_sample_ratio = 1.0

otlp_metrics = {
  endpoint             = ""
  protocol             = "grpc"
  export_interval_secs = 60
  basic_auth_username  = ""
  basic_auth_password  = ""
}

host_metrics_enabled = false

otlp_logs = {
  endpoint             = ""
  protocol             = "grpc"
  export_interval_secs = 60
  basic_auth_username  = ""
  basic_auth_password  = ""
}

otlp_traces = {
  endpoint             = ""
  protocol             = "grpc"
  export_interval_secs = 60
  basic_auth_username  = ""
  basic_auth_password  = ""
}
