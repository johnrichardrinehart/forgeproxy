# Required variables — copy this file to terraform.tfvars and fill in values.

upstream_hostname  = "ghe.example.com"
upstream_api_url   = "https://ghe.example.com/api/v3"
nlb_tls_cert_arns_by_hostname = {
  "forgeproxy.example.com" = "arn:aws:acm:us-east-1:123456789012:certificate/11111111-2222-3333-4444-555555555555"
}
bundle_bucket_name = "my-forgeproxy-bundles"
force_destroy      = false

# Optional overrides (uncomment to customise):
# aws_region               = "us-east-1"
# aws_profile              = "your-sso-profile"
# name_prefix              = "forgeproxy"
# flake_ref                = "github:johnrichardrinehart/forgeproxy"
# closure_variant          = "hardened" # or "dev"
# disallow_local_nix_builds = false
# forgeproxy_instance_type = "t3.large"
# forgeproxy_count         = 1
# forgeproxy_root_volume_iops = 3000
# forgeproxy_root_volume_throughput_mbps = 125
# valkey_instance_type      = "r6i.large"
# enable_ghe_key_lookup    = true
# ghe_key_lookup_ssh_target_endpoint = "ghe.example.com"
# ghe_key_lookup_ghe_url   = "https://ghe.example.com"
# nlb_internal             = true
# nlb_tls_ssl_policy       = "ELBSecurityPolicy-TLS13-1-2-2021-06"
# metrics_enabled          = true
# metrics_refresh_interval_secs = 60
# config_reload_enabled = true
# config_reload_interval_secs = 60
# prepare_published_generation_indexes = false
# global_short_circuit_upstream_secs = 0
# request_wait_for_local_catch_up_secs = 30
# request_wait_for_active_local_catch_up_secs = 300
# request_time_s3_restore_secs = 0
# generation_publish_secs = 0
# local_upload_pack_first_byte_secs = 0
# delegated_repositories = []
# pack_cache_on_demand_composite_total_secs = 0
# pack_cache_request_delta_pack_secs = 0
# pack_cache_max_concurrent_background_warmings = 1
# prewarm_enabled       = false
# prewarm_repos         = []
# prewarm_max_concurrent = 2
# bundle_pack_threads      = 4
# logs_enabled             = true
# traces_enabled           = false
# traces_sample_ratio      = 1.0
# log_level                = "info"
