# Required variables — copy this file to terraform.tfvars and fill in values.

upstream_hostname  = "ghe.example.com"
upstream_api_url   = "https://ghe.example.com/api/v3"
proxy_fqdn         = "forgeproxy.example.com"
bundle_bucket_name = "my-forgeproxy-bundles"
force_destroy      = false

# Optional overrides (uncomment to customise):
# aws_region               = "us-east-1"
# aws_profile              = "your-sso-profile"
# name_prefix              = "forgeproxy"
# flake_ref                = "github:johnrichardrinehart/forgeproxy"
# closure_variant          = "hardened" # or "dev"
# forgeproxy_instance_type = "t3.large"
# forgeproxy_count         = 1
# valkey_instance_type      = "r6i.large"
# enable_ghe_key_lookup    = true
# ghe_key_lookup_ssh_target_endpoint = "ghe.example.com"
# ghe_key_lookup_ghe_url   = "https://ghe.example.com"
# nlb_internal             = true
# log_level                = "info"
